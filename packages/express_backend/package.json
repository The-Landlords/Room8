{
	"name": "express_backend",
	"version": "1.0.0",
	"description": "",
	"main": "backend.ts",
	"type": "module",
	"scripts": {
		"start": "tsx watch backend.ts",
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"lint:check": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --max-warnings=0 --fix --format stylish",
		"format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
		"format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
		"test": "jest --config ./jest.config.cjs --runInBand",
		"coverage": "jest --config ./jest.config.cjs --runInBand --coverage",
		"test:mock": "jest --runInBand --testMatch '**/*Mock.test.ts'"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"ics": "^3.12.0",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"mockingoose": "^3.0.0",
		"mongoose": "^9.1.5"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"eslint-formatter-unix": "^9.0.1",
		"jest": "^30.3.0",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
