{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "commonjs",
		"moduleResolution": "node",
		"jsx": "react-jsx",
		"verbatimModuleSyntax": false,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["jest", "node"]
	},
	"include": ["src"]
}
