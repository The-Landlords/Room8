{
	"name": "room8",
	"version": "1.0.0",
	"description": "Roomate organization app",
	"main": "index.js",
	"scripts": {
		"tf": "npm run test:frontend",
		"tb": "npm run test:backend",
		"test": "npm run test:frontend && npm run test:backend",
		"test:frontend": "vitest run packages/react-frontend/src/Testing --environment jsdom",
		"test:frontend:watch": "vitest packages/react-frontend/src/Testing --environment jsdom",
		"test:backend": "jest --selectProjects backend --runInBand",
		"coverage": "npm run coverage:backend && npm run coverage:frontend",
		"coverage:backend": "jest --selectProjects backend --runInBand --coverage",
		"coverage:frontend": "vitest run packages/react-frontend/src/Testing --environment jsdom --coverage",
		"frontend": "npm -w packages/react-frontend run dev",
		"backend": "npm -w packages/express_backend run start",
		"build": "npm -w packages/react-frontend run build && npm -w packages/express_backend run build",
		"dev": "concurrently --kill-others -c red,blue \"npm -w packages/react-frontend run dev\" \"npm -w packages/express_backend run dev\"",
		"lint:check": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
		"lint:fix": "eslint \"packages/*/src/**/*.{ts,tsx}\" --fix",
		"format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
		"format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
		"swagger": "npm -w packages/express_backend run swagger",
		"cy:open": "cypress open",
		"cy:component": "cypress run --component",
		"cy:e2e": "concurrently -c red,blue \"npm run dev\" \"cypress run --e2e\"",
		"cy:run": "npm run cy:component && npm run cy:e2e"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/The-Landlords/Room8.git"
	},
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/The-Landlords/Room8/issues"
	},
	"homepage": "https://github.com/The-Landlords/Room8#readme",
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"@babel/preset-env": "^7.29.5",
		"@babel/preset-react": "^7.28.5",
		"@babel/preset-typescript": "^7.28.5",
		"@eslint/js": "^9.39.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/express-session": "^1.19.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.2.0",
		"@types/swagger-jsdoc": "^6.0.4",
		"@types/swagger-ui-express": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.6",
		"babel-jest": "^30.3.0",
		"cy-ai": "^0.0.0",
		"cypress": "^15.16.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^6.15.0",
		"eslint-plugin-react": "^7.37.5",
		"globals": "^17.2.0",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"jsdom": "^29.1.1",
		"mockingoose": "^3.0.0",
		"postcss": "^8.5.15",
		"prettier": "^3.8.3",
		"start-server-and-test": "^2.1.5",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@maptiler/geocoding-control": "^3.0.0",
		"bcrypt": "^6.0.0",
		"connect-mongo": "^6.0.0",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express-session": "^1.19.0",
		"ics": "^3.11.0",
		"lint": "^1.2.2",
		"ol": "^10.9.0",
		"react-router-dom": "^7.13.0",
		"swagger-autogen": "^2.23.7",
		"swagger-jsdoc": "^6.2.8",
		"swagger-ui-express": "^5.0.1",
		"typescript-eslint": "^8.56.0"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu": "^4.60.2"
	},
	"allowScripts": {
		"@scarf/scarf": true,
		"bcrypt": true,
		"cypress": true,
		"esbuild": true,
		"unrs-resolver": true
	}
}
