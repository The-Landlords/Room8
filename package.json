{
	"name": "room8",
	"version": "1.0.0",
	"description": "Roomate organization app",
	"main": "index.js",
	"scripts": {
		"test": "jest --runInBand",
		"coverage": "jest --runInBand --coverage",
		"frontend": "npm -w packages/react-frontend run dev",
		"backend": "npm -w packages/express_backend run start",
		"dev": "concurrently --kill-others -c red,blue \"npm -w packages/react-frontend run dev\" \"npm -w packages/express_backend run start\"",
		"lint": "eslint . --fix",
		"format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
		"format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\""
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/The-Landlords/Room8.git"
	},
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/The-Landlords/Room8/issues"
	},
	"homepage": "https://github.com/The-Landlords/Room8#readme",
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.2.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^6.15.0",
		"eslint-plugin-react": "^7.37.5",
		"globals": "^17.2.0",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"mockingoose": "^3.0.0",
		"prettier": "^3.8.3",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0"
	},
	"dependencies": {
		"@maptiler/geocoding-control": "^3.0.0",
		"dotenv": "^17.3.1",
		"ics": "^3.11.0",
		"lint": "^1.1.2",
		"ol": "^10.9.0",
		"react-router-dom": "^7.13.0",
		"typescript-eslint": "^8.56.0"
	}
}
